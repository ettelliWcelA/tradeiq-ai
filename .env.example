# ============================================================
# TradeIQ AI — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control
# ============================================================

# ── Robinhood Credentials ─────────────────────────────────
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_robinhood_password

# Your TOTP secret (from Robinhood 2FA setup — see SETUP GUIDE)
# This is the 16-character alphanumeric code from the "Can't scan" step
ROBINHOOD_TOTP_SECRET=AAAA1111BBBB2222

# ── AI Integration (for morning briefings) ────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Email Notifications ───────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=briefing@yourdomain.com
EMAIL_TO=you@youremail.com

# ── Trading Mode ──────────────────────────────────────────
# Set to "true" for paper mode (DRY RUN - NO REAL ORDERS)
# Set to "false" ONLY after successful paper testing
PAPER_MODE=true

# ── Risk Parameters ───────────────────────────────────────
ACCOUNT_SIZE=10000
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_CONCURRENT_POSITIONS=3
DEFAULT_RR_RATIO=3.0
